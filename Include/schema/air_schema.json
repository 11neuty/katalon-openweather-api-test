{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["list"],
  "properties": {
    "list": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["main", "components"],
        "properties": {
          "main": {
            "type": "object",
            "required": ["aqi"],
            "properties": {
              "aqi": {
                "type": "integer",
                "minimum": 1,
                "maximum": 5
              }
            }
          },
          "components": {
            "type": "object",
            "required": ["co", "pm2_5", "pm10"],
            "properties": {
              "co": { "type": "number" },
              "pm2_5": { "type": "number" },
              "pm10": { "type": "number" }
            }
          }
        }
      }
    }
  }
}